flowchart TD
    %% Styles
    classDef raw fill:#ffffff,stroke:#000000,color:black;
    classDef phase fill:#dae8fc,stroke:#6c8ebf,color:black;
    classDef script fill:#fff2cc,stroke:#d6b656,color:black;
    classDef artifact fill:#d5e8d4,stroke:#82b366,color:black;
    classDef env fill:#f8cecc,stroke:#b85450,color:black;
    classDef decision fill:#e1d5e7,stroke:#9673a6,color:black;

    %% ==========================================================
    %% Phase 0: Data extraction / formatting (CPU-heavy)
    %% ==========================================================
    subgraph P0["Phase 0: Raw → MEDS (CPU-heavy)"]
        direction TB
        ENV0[conda env: meds-extract<br/>MEDS_transforms==0.1.1<br/>polars<=1.27.9<br/>(see scripts/setup_conda_env_meds_extract.sh)]:::env
        RAW[MIMIC-IV v3.1 raw CSVs<br/>physionet.org/files/mimiciv/3.1/]:::raw
        CFG[event_configs_v3.1_full.yaml<br/>storetime semantics + ICU tables<br/>adds ref_range_lower/ref_range_upper]:::script
        PRE[pre_MEDS.py]:::script
        PIPE[MEDS_transform-runner<br/>extract_MIMIC_local.yaml<br/>row_chunksize=100,000,000 (OOM mitigation)<br/>+ local_parallelism_runner.yaml]:::script
        MEDS[MEDS cohort parquet<br/>benchmarks/mimic-meds-extraction/data/meds/]:::artifact

        ENV0 --> PRE
        RAW --> PRE --> PIPE
        CFG --> PIPE --> MEDS
    end

    %% ==========================================================
    %% Optional CLIF arm formatting (Experiment 3)
    %% ==========================================================
    subgraph P0B["Phase 0b: Raw → CLIF (for Exp3)"]
        direction TB
        RAW2[MIMIC-IV v3.1 raw CSVs]:::raw
        CLIFEXT[External: CLIF-MIMIC conversion<br/>(produces CLIF-2.1 parquet tables)]:::script
        SPLIT[split_clif_by_patient_splits.py<br/>creates raw/{train,val,test} splits]:::script
        CLIFRAW[CLIF parquet tables (split)<br/>data/clif/raw/{train,val,test}/]:::artifact
        AUG[augment_clif_labs_with_ref_ranges.py<br/>adds ref_range_lower/ref_range_upper to clif_labs]:::script
        CLIFREF[CLIF parquet tables (augmented)<br/>data/clif/raw/.../clif_labs.parquet]:::artifact

        RAW2 --> CLIFEXT --> SPLIT --> CLIFRAW --> AUG --> CLIFREF
    end

    %% ==========================================================
    %% Phase 1: Tokenization (CPU-heavy)
    %% ==========================================================
    subgraph P1["Phase 1: Tokenization"]
        direction TB
        ENV1[conda env: input-rep<br/>polars>=1.33<br/>fms-ehrs + benchmark deps<br/>(see scripts/setup_conda_env_input_rep.sh)]:::env
        MAP{Exp3:<br/>semantic mapping intervention<br/>(native vs standardized vs null controls)}:::decision
        TOK[tokenize_w_config.py<br/>reads data/raw/{train,val,test}<br/>writes *-tokenized + *_first_24h-tokenized<br/>and exports numeric_stats.json (median/IQR)]:::script
        TOKOUT[Tokenized timelines parquet<br/>tokens + numeric_values + times]:::artifact
        ENV1 --> TOK
    end

    %% ==========================================================
    %% Phase 2: Pretraining / representation training (GPU)
    %% ==========================================================
    subgraph P2["Phase 2: Pretraining / Representation Training (GPU)"]
        direction TB
        EXP1[tune_model.py<br/>Experiment 1 (discrete LM)]:::script
        EXP2[train_representation.py<br/>Experiment 2 (discrete/soft/continuous)]:::script
        DEC2{Select Exp2 winner<br/>(representation + temporal)}:::decision
        CKPT[Model checkpoints]:::artifact
        EXP1 --> CKPT
        EXP2 --> CKPT --> DEC2
    end

    %% ==========================================================
    %% Phase 3: Evaluation (GPU + CPU)
    %% ==========================================================
    subgraph P3["Phase 3: eval (reps → logistic regression)"]
        direction TB
        OUTM[extract_outcomes_meds.py<br/>labels joined onto *_first_24h-tokenized]:::script
        OUTC[fms_ehrs/scripts/extract_outcomes.py<br/>labels from CLIF tokens (if needed)]:::script
        EXTRACT[extract_hidden_states.py<br/>torchrun (2 GPUs)<br/>writes features-*.npy]:::script
        LR[transfer_rep_based_preds.py<br/>classifier=logistic_regression<br/>(CPU tier2q)]:::script
        METRICS[Metrics tables + saved preds<br/>(precision/recall/F1/AUROC)]:::artifact
        OUTM --> EXTRACT --> LR --> METRICS
        OUTC --> EXTRACT
    end

    %% ==========================================================
    %% Phase gating (no-placeholder scheduling)
    %% ==========================================================
    subgraph GATE["Scheduling / selection gates (no placeholders)"]
        direction TB
        DEC1{Select Exp1 winner<br/>(tokenization regime)}:::decision
        NOTE2[Exp2 may start early with<br/>soft/continuous × {time_tokens,time2vec}<br/>under an explicitly declared regime]:::decision
        NOTE3[Exp3 must wait for Exp1+Exp2 winners<br/>because Exp3 retrains MEDS on ICU-aligned cohort<br/>(fair MEDS vs CLIF comparison)]:::decision
        DEC1 --> NOTE2 --> DEC2 --> NOTE3
    end

    %% ==========================================================
    %% Orchestration (SLURM)
    %% ==========================================================
    subgraph SLURM["SLURM orchestration"]
        direction TB
        S0[slurm/01_phase0_extract_meds.sh<br/>sets IRB_CONDA_ENV=meds-extract]:::script
        S1[slurm/90_stage0_tokenize_only_debug.sh<br/>sets IRB_CONDA_ENV=input-rep<br/>(manual tokenization helper)]:::script
        RUNCPU[slurm/02_run_stage0_tier2q_tokenize.sh<br/>Stage0 runner (tier2q CPU)]:::script
        RUN4[slurm/05_run_stage1_gpu4_train.sh<br/>Stage1 runner (4 GPUs/job; packs 2 jobs/node)]:::script
        RUN8[slurm/05_run_stage1_gpu8_train.sh<br/>Stage1 runner (8 GPUs/job; optional)]:::script
        RUN2[slurm/09_run_stage2_gpu2_extract.sh<br/>Stage2 extract (2 GPUs/job)]:::script
        RUNT2Q[slurm/11_run_stage3_tier2q_lr.sh<br/>Stage3 LR (CPU tier2q)]:::script
        S0 --> S1 --> RUNCPU --> RUN4 --> RUN2 --> RUNT2Q
    end

    %% Cross-phase connections
    MEDS --> TOK
    CLIFREF --> MAP --> TOK
    TOK --> TOKOUT --> EXP1
    TOKOUT --> EXP2
    CKPT --> EXTRACT

